# Copy to .env and fill in. Do NOT commit the real .env (it is gitignored).

# --- Core app ---
PORT=3000
URL=http://localhost:3000            # base URL; also used for internal API calls
DATABASE_URL=                        # MongoDB connection string
YEAR=2025                            # current season

# --- Auth0 (express-openid-connect) ---
AUTH_SECRET=                         # long random string
CLIENT_ID=
ISSUER_BASE_URL=

# --- College Football Data API ---
CFBD_API_KEY=

# --- Internal API token ---
# Shared secret that lets the scheduled jobs / scoring modules authenticate to
# the app's own API. MUST be set to the SAME value on the web host AND wherever
# the jobs run, or nightly score updates will fail with 401.
INTERNAL_API_TOKEN=                  # long random string

# --- Email (nodemailer / Gmail) ---
GMAIL_USER=                          # sender Gmail address
GMAIL_APP_PASSWORD=                  # Gmail app password (NOT your account password)
