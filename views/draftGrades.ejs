<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="draftGrades.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Graduate&family=Pacifico&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <script defer src="draftGrades.js"></script>
    <title>Draft Grades · Campus Clash</title>
    <link rel="shortcut icon" type="image/png" href="images/favicon.png"/>
</head>
<body>
    <%- include('partials/navbar') %>
    <% if (userState) { %>
        <script>
            var userState = <%- userState %>;
        </script>
    <% } %>

    <div class="grades-container">
        <div class="grades-head">
            <h1 class="header-title">Draft Grades</h1>
            <div class="grades-controls">
                <label for="grades-season">Season</label>
                <select id="grades-season" grades-season>
                    <% for (var y = Number(year); y >= 2023; y--) { %>
                        <option value="<%= y %>"><%= y %></option>
                    <% } %>
                </select>
            </div>
        </div>

        <p class="grades-note">
            Graded on a curve within your league by <strong>draft value</strong> — how much each pick
            outperformed its draft slot (a team's fantasy points vs. where it was taken). Distinct from the
            standings; it rewards finding late-round steals. Grades fill in as the season is scored.
        </p>

        <div id="grades-container" class="grades-grid"></div>
    </div>

    <footer>
        <a href="https://collegefootballdata.com/" class="cfb-data">Powered by College Football Data</a>
    </footer>
</body>
</html>
